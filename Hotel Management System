void deleteBooking() {
    FILE *fp = fopen("booking.txt", "r");
    FILE *temp = fopen("temp.txt", "w");

    if (!fp) {
        printf(RED "No booking records exist.\n" RESET);
        if (temp) fclose(temp);
        return;
    }
    if (!temp) {
        printf(RED "Unable to create temporary file.\n" RESET);
        fclose(fp);
        return;
    }

    char phone[20];
    printf("\n" YELLOW BOLD "--- DELETE BOOKING ---\n" RESET);
    printf(CYAN "Enter Phone Number of the Reservation: " RESET);
    scanf("%s", phone);

    char line[512];
    int found = 0;

    while (fgets(line, sizeof(line), fp)) {
        if (strstr(line, phone)) {
            found = 1;
            continue;
        }
        fputs(line, temp);
    }

    fclose(fp);
    fclose(temp);
    remove("booking.txt");
    rename("temp.txt", "booking.txt");

    if (found)
        printf(GREEN "Reservation deleted successfully!\n" RESET);
    else
        printf(RED "No reservation found for that phone number.\n" RESET);
}

