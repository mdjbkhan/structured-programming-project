void viewBookings() {
    FILE *fp = fopen("booking.txt", "r");
    if (!fp) {
        printf(RED "No booking records found.\n" RESET);
        return;
    }

    printf("\n" YELLOW BOLD "--- ALL BOOKINGS ---\n" RESET);

    char name[50], phone[20], roomType[20];
    int rooms, day, month, year, stayDays, pricePerDay, totalPrice;

    while (fscanf(fp, "%49s %19s %19s %d %d-%d-%d %d %d %d",
                  name, phone, roomType, &rooms,
                  &day, &month, &year,
                  &stayDays, &pricePerDay, &totalPrice) == 10) {

        printf(CYAN "\nName        : " WHITE "%s\n" RESET, name);
        printf(CYAN "Phone       : " WHITE "%s\n" RESET, phone);
        printf(CYAN "Room Type   : " WHITE "%s\n" RESET, roomType);
        printf(CYAN "Rooms       : " WHITE "%d\n" RESET, rooms);
        printf(CYAN "From Date   : " WHITE "%02d-%02d-%04d\n" RESET, day, month, year);
        printf(CYAN "Stay Days   : " WHITE "%d\n" RESET, stayDays);
        printf(CYAN "Price/Day   : " WHITE "%d\n" RESET, pricePerDay);
        printf(CYAN "Total Price : " WHITE "%d\n" RESET, totalPrice);
        printf(DIM "-----------------------------------------\n" RESET);
    }

    fclose(fp);
}

