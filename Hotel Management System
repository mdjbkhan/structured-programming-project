void booking() {
    struct Booking b;
    FILE *fp = fopen("booking.txt", "a");

    if (!fp) {
        printf(RED "File error!\n" RESET);
        return;
    }

    printf("\n" YELLOW BOLD "--- ROOM BOOKING ---\n" RESET);
    printf(CYAN "Name: " RESET);
    scanf("%49s", b.name);
    printf(CYAN "Phone: " RESET);
    scanf("%19s", b.phone);

    int typeChoice;
    printf("\n" WHITE BOLD "Select Room Type:\n" RESET);
    printf(WHITE "1. Single  - 1500 per day\n" RESET);
    printf(WHITE "2. Double  - 2500 per day\n" RESET);
    printf(WHITE "3. Suite   - 4000 per day\n" RESET);
    printf(CYAN "Choose (1-3): " RESET);

    if (scanf("%d", &typeChoice) != 1) {
        printf(RED "Invalid input!\n" RESET);
        fclose(fp);
        return;
    }

    switch (typeChoice) {
        case 1: strcpy(b.roomType, "Single"); b.pricePerDay = 1500; break;
        case 2: strcpy(b.roomType, "Double"); b.pricePerDay = 2500; break;
        case 3: strcpy(b.roomType, "Suite");  b.pricePerDay = 4000; break;
        default:
            printf(RED "Invalid room type!\n" RESET);
            fclose(fp);
            return;
    }

    printf(CYAN "No. of Rooms: " RESET);
    if (scanf("%d", &b.rooms) != 1) {
        printf(RED "Invalid input!\n" RESET);
        fclose(fp);
        return;
    }

    printf("\n" WHITE BOLD "Enter Booking Start Date:\n" RESET);
    printf(CYAN "Day   : " RESET); scanf("%d", &b.fromDay);
    printf(CYAN "Month : " RESET); scanf("%d", &b.fromMonth);
    printf(CYAN "Year  : " RESET); scanf("%d", &b.fromYear);

    printf(CYAN "How many days will you stay? " RESET);
    scanf("%d", &b.stayDays);

    b.totalPrice = b.rooms * b.stayDays * b.pricePerDay;

    fprintf(fp, "%s %s %s %d %02d-%02d-%04d %d %d %d\n",
            b.name, b.phone, b.roomType, b.rooms,
            b.fromDay, b.fromMonth, b.fromYear,
            b.stayDays, b.pricePerDay, b.totalPrice);

    printf(GREEN "\nBooking Successful!\n" RESET);
    fclose(fp);
}

void restaurant() {
    struct Order o;
    FILE *fp = fopen("orders.txt", "a");

    if (!fp) {
        printf(RED "File error!\n" RESET);
        return;
    }

    int more = 1;
    int grandTotal = 0;

    printf("\n" YELLOW BOLD "--- RESTAURANT ORDER ---\n" RESET);
    printf(CYAN "Room Number: " RESET);

    if (scanf("%d", &o.roomNo) != 1) {
        printf(RED "Invalid input!\n" RESET);
        fclose(fp);
        return;
    }

    while (more == 1) {
        int foodChoice;

        printf("\n" YELLOW BOLD "--- MENU ---\n" RESET);
        printf(WHITE "1. Fried Rice      - 250\n" RESET);
        printf(WHITE "2. Chicken Curry   - 300\n" RESET);
        printf(WHITE "3. Burger          - 200\n" RESET);
        printf(WHITE "4. Coffee          - 100\n" RESET);
        printf(WHITE "5. Water           -  30\n" RESET);
        printf(CYAN "Choose item (1-5): " RESET);

        if (scanf("%d", &foodChoice) != 1) {
            flushInput();
            printf(RED "Invalid input!\n" RESET);
            continue;
        }

        switch (foodChoice) {
            case 1: strcpy(o.item, "Fried_Rice");    o.unitPrice = 250; break;
            case 2: strcpy(o.item, "Chicken_Curry"); o.unitPrice = 300; break;
            case 3: strcpy(o.item, "Burger");        o.unitPrice = 200; break;
            case 4: strcpy(o.item, "Coffee");        o.unitPrice = 100; break;
            case 5: strcpy(o.item, "Water");         o.unitPrice =  30; break;
            default:
                printf(RED "Invalid choice! Try again.\n" RESET);
                continue;
        }

        printf(CYAN "Quantity: " RESET);
        if (scanf("%d", &o.quantity) != 1) {
            flushInput();
            printf(RED "Invalid input!\n" RESET);
            continue;
        }

        o.totalPrice = o.unitPrice * o.quantity;
        grandTotal += o.totalPrice;

        printf("\n" YELLOW BOLD "--- ITEM SUMMARY ---\n" RESET);
        printf(WHITE "Item        : %s\n" RESET, o.item);
        printf(WHITE "Unit Price  : %d\n" RESET, o.unitPrice);
        printf(WHITE "Quantity    : %d\n" RESET, o.quantity);
        printf(WHITE "Subtotal    : %d\n" RESET, o.totalPrice);

        fprintf(fp, "%d %s %d %d %d\n",
                o.roomNo, o.item, o.unitPrice, o.quantity, o.totalPrice);

        printf(CYAN "\nAdd another item? (1 = Yes, 0 = No): " RESET);
        if (scanf("%d", &more) != 1) {
            more = 0;
            flushInput();
        }
    }

    printf("\n" YELLOW BOLD "=== FINAL RESTAURANT BILL ===\n" RESET);
    printf(WHITE "Room No     : %d\n" RESET, o.roomNo);
    printf(WHITE "Grand Total : %d\n" RESET, grandTotal);
    printf(GREEN "Order Placed Successfully!\n" RESET);

    fclose(fp);
}

